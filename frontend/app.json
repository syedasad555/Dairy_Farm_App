{
  "expo": {
    "name": "MVR Farms",
    "slug": "mvr-farms",
    "version": "2.0.0",
    "orientation": "portrait",
    "scheme": "mvrfarms",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#2D5016"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mvrfarms.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "MVR Farms needs your location for delivery tracking and proof of delivery.",
        "NSCameraUsageDescription": "MVR Farms needs camera access to capture delivery proof photos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2D5016"
      },
      "package": "com.mvrfarms.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow MVR Farms to use your location for delivery tracking."
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "Allow MVR Farms to take delivery proof photos."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#2D5016"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "your-eas-project-id"
      }
    }
  }
}
