# ── Local emulator mode ──
EXPO_PUBLIC_USE_FIREBASE_EMULATOR=true
EXPO_PUBLIC_FIREBASE_PROJECT_ID=dairy-farm-121a6

# Optional: override auto-detected LAN IP (Expo Go usually detects this automatically)
# EXPO_PUBLIC_EMULATOR_HOST=192.168.29.198

# Firebase Emulator ports (PC must run: cd firebase && npm run emulators)
#   Auth:      9099
#   Firestore: 8080
#   Functions: 5001
#   Storage:   9199
#   UI:        http://YOUR_PC_IP:4000
#
# Expo Metro (frontend): port 8081 — scan QR in Expo Go
#
# Test logins after npm run emulators:seed:
#   Admin    9999999999 / admin123
#   Customer 9876543210 / customer123
#   Partner  9888888888 / partner123
